Dim ReturnBalls,GameOver
Sub TriggerReturnBalls_Hit
	ReturnBallsTimer.Enabled = True
	ReturnBalls = True
End Sub
Sub TriggerReturnBalls_UnHit
	ReturnBallsTimer.Enabled = False
	ReturnBalls = False
End Sub
Sub ReturnBallsTimer_Timer
	If BallVel(ControlActiveBall) = 0 and ReturnBalls = True Then
		BIP = BIP - (TriggerEndofPlayfield.BallCntOver + 1)
		While TriggerReturnBalls.BallCntOver >0:TriggerReturnBalls.DestroyBall:Wend
		While TriggerEndofPlayfield.BallCntOver >0:TriggerEndofPlayfield.DestroyBall:Wend		
		PlaySound "knocker",0,0.75,0,0.25,0,0,1,0
		If B2SOn Then Controller.B2SStartAnimation "ReplayBalls"
		debug.print "*** REPLAY ***"
		ReturnBallsTimer.Enabled = False
		NextBall
	End If
End Sub

Sub TriggerGameOver_Hit
	GameOverTimer.Enabled = True
	GameOver = True
End Sub
Sub TriggerGameOver_UnHit
	GameOverTimer.Enabled = False
	GameOver = False
End Sub 

Sub GameOverTimer_Timer
	If BallVel(ControlActiveBall) = 0 and GameOver = True Then
		BIP = maxBalls
		GameOverTimer.Enabled = False
		PlaySound "knocker",0,0.75,0,0.25,0,0,1,0
		debug.print "*** GAME OVER ***"
		If B2SOn Then Controller.B2SSetScore 1, PlayerScore
		EndGame
	End If
End Sub


Dim PlayerScore,CurrentBall
Sub Addpoints(ScorePar)
		if GameStarted Then			
						
			If ActiveBall.ID = BIP Then CurrentBall = True Else CurrentBall = False End If 
		end If
		If ScorePar > 1 Then
			PlayerScore = PlayerScore + ScorePar
			debug.print "Ball " & ActiveBall.ID & " hit       " & ScorePar & " =" & PlayerScore
			If CurrentBall = True Then NextBall:End If
		ElseIf ScorePar = 0 Then
			debug.print "Ball " & ActiveBall.ID & " hit end   " & ScorePar & " =" & PlayerScore & " - " & TriggerEndofPlayfield.BallCntOver & " lost"
			If CurrentBall = True Then NextBall:End If
		Elseif ScorePar = -1 Then
			debug.print "Ball " & ActiveBall.ID & " unhit end " & ScorePar & " =" & PlayerScore
		Else
			PlayerScore = PlayerScore + ScorePar
			debug.print "Ball " & ActiveBall.ID & " hit       " & ScorePar & " =" & PlayerScore
		End If
		
End Sub





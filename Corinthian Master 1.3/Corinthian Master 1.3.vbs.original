'First, try to load the Controller.vbs (DOF), which helps controlling additional hardware like lights, gears, knockers, bells and chimes (to increase realism)
'This table uses DOF via the 'SoundFX' calls that are inserted in some of the PlaySound commands, which will then fire an additional event, instead of just playing a sample/sound effect
On Error Resume Next
ExecuteGlobal GetTextFile("controller.vbs")
If Err Then MsgBox "You need the Controller.vbs file in order to run this table (installed with the VPX package in the scripts folder)"
On Error Goto 0

'If using Visual PinMAME (VPM), place the ROM/game name in the constant below,
'both for VPM, and DOF to load the right DOF config from the Configtool, whether it's a VPM or an Original table


If Table1.ShowDT = false then
    Scoretext.Visible = false
End If
Const cGameName = ""
Const cController = 3

Dim EnableBallControl,Object
Dim Controller
EnableBallControl = false 'Change to true to enable manual ball control (or press C in-game) via the arrow keys and B (boost movement) keys

Const BallSize = 27  'Ball radius
Const maxBalls =10
Const VolumeMultiplier = 10 		'adjusts table sound volume
Const ShowHighScore = True			'enable to show HighScore tape on Apron, a new HighScore will be saved anyway
Const ShowPlayfieldReel = True		'set to True to show Playfield EM-Reel and Post-It for Player Scores
Const FreePlay = True
const RollingSoundFactor = 2.5		'set sound level factor here for Ball Rolling Sound, 1=default level


debug.print "testing"
Dim BIP,i

Sub Table1_Init
	LoadEM
	loadhs
	if HSA1="" then HSA1=25
	if HSA2="" then HSA2=25
	if HSA3="" then HSA3=25
	UpdatePostIt
	If B2SOn Then Controller.B2SSetGameOver 1
End Sub

Sub Table1_KeyDown(ByVal keycode)

	If keycode = StartGameKey And Not HSEnterMode=true Then
		StartGame
	End If

	If keycode = PlungerKey Then
		Plunger.PullBack
		PlaySound "plungerpull",0,1,AudioPan(Plunger),0.25,0,0,1,AudioFade(Plunger)
	End If


	If keycode = LeftTiltKey Then
		Nudge 90, 2
	End If

	If keycode = RightTiltKey Then
		Nudge 270, 2
	End If

	If keycode = CenterTiltKey Then
		Nudge 0, 2
	End If

    ' Manual Ball Control
	If keycode = 46 Then	 				' C Key
		If EnableBallControl = 1 Then
			EnableBallControl = 0
		Else
			EnableBallControl = 1
		End If
	End If
    If EnableBallControl = 1 Then
		If keycode = 48 Then 				' B Key
			If BCboost = 1 Then
				BCboost = BCboostmulti
			Else
				BCboost = 1
			End If
		End If
		If keycode = 203 Then BCleft = 1	' Left Arrow
		If keycode = 200 Then BCup = 1		' Up Arrow
		If keycode = 208 Then BCdown = 1	' Down Arrow
		If keycode = 205 Then BCright = 1	' Right Arrow
	End If

	If HSEnterMode Then HighScoreProcessKey(keycode) End If

End Sub


Sub Table1_KeyUp(ByVal keycode)
	If keycode = PlungerKey Then
		Plunger.Fire
		PlaySound "plunger",0,1,AudioPan(Plunger),0.25,0,0,1,AudioFade(Plunger)
	End If


    'Manual Ball Control
	If EnableBallControl = 1 Then
		If keycode = 203 Then BCleft = 0	' Left Arrow
		If keycode = 200 Then BCup = 0		' Up Arrow
		If keycode = 208 Then BCdown = 0	' Down Arrow
		If keycode = 205 Then BCright = 0	' Right Arrow
	End If
End Sub

Sub StartGame
		if not GameStarted Then
			BIP = 0
			PlaySound "PNK_chime_10",0,0.75,0,0.25,0,0,1,0			
			'for i = 0 to maxBalls:ClearBalls:Next 'Brute force this to clear all balls
			ClearBalls
			GameStarted = True
			GameEndTimer.enabled = False
			PlayerScore=0
			debug.print "########## Start Game ############"
			NextBall
			
			If B2SOn Then Controller.B2SStopAnimation "Attract" 'turn off Attract
			If B2SOn Then Controller.B2SSetGameOver 0 'turn off Gameover light
			If B2SOn Then Controller.B2SSetScore 1, PlayerScore
		end If
End Sub






Sub ClearBalls
	For Each Object in Triggers
		while Object.BallCntOver >0
			debug.print Object.Name & " - " & Object.BallCntOver &" Destroyed"
			Object.DestroyBall
		Wend		
	Next
	For Each Object in Kickers
		while Object.BallCntOver >0
			debug.print Object.Name & " - " & Object.BallCntOver &" Destroyed"
			Object.DestroyBall
		Wend
	Next
End Sub

Sub NextBall()
	BallReleaseTimer.enabled = True
End Sub

Sub BallReleaseTimer_Timer
	If GameStarted = True Then
		If BIP < maxBalls Then
			BIP = BIP + 1
			If B2SOn Then Controller.B2SSetScore 1, PlayerScore
			BallReleaseTimer.enabled = False
			BallRelease.CreateSizedBall(BallSize).ID = BIP
			BallRelease.Kick 0, 7
			DOF 122, DOFPulse
		Else
			If B2SOn Then Controller.B2SSetScore 1, PlayerScore
			EndGame
		End If
	End If
End Sub

Sub GameEndTimer_Timer
	
	GameEndTimer.enabled = False
	EndGame
End Sub

Sub EndGame
	debug.print "**********  End Game ************"
	GameStarted = False
	BIP = 0
	CheckNewHighScorePostIt(PlayerScore)
	If B2SOn Then Controller.B2SSetGameOver 1
	
PlaySound "PNK_chime_10",0,0.75,0,0.25,0,0,1,0
PlaySound "PNK_chime_10",0,0.75,0,0.25,0,0,1,0
End Sub

Sub CheckNewHighScorePostIt(newScore)
		If CLng(newScore) > CLng(HSAHighScore) Then 
			HSAHighScore=newScore
			HighScoreEntryInit()
		Else
			If B2SOn Then Controller.B2SStartAnimation "Attract" 'turn on Attract
		End If
End Sub



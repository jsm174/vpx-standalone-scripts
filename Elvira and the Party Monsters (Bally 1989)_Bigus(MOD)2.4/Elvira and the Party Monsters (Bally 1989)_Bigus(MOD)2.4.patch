+Function SafePercent(v, defaultPercent)
+	'coerce a settings value to a 0..1 fraction with a fallback default percent (0..100)
+	'guards against missing/empty/non-numeric INI values that would cause type mismatch
+	If IsNumeric(v) Then
+		SafePercent = CDbl(v) / 100
+	Else
+		SafePercent = CDbl(defaultPercent) / 100
+	End If
+End Function
